# Copy to `.env` and edit. Compose auto-loads `.env` from the project root.

# ---- Database ----
DB_URL=jdbc:postgresql://postgres:5432/gpu-hub
DB_USERNAME=postgres
DB_PASSWORD=1234
HIBERNATE_DDL=update

# ---- Object storage (MinIO) ----
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---- Kubernetes ----
KUBERNETES_KUBECONFIG_BUCKET=kubeconfig

# ---- JWT ----
JWT_SECRET=A0adcU92dc7DOhOv8xXmpUuZwHmAhhW7OjCe2YdQn3A=
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# ---- App ----
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@gmail.com.vn
ADMIN_BOOTSTRAP_PASSWORD=admin

# ---- JVM ----
JAVA_OPTS=

# ---- Host port mappings ----
BACKEND_PORT=8080
FRONTEND_PORT=80

# ---- Frontend → backend wiring (rendered into nginx.conf at start) ----
FRONTEND_BACKEND_HOST=backend
FRONTEND_BACKEND_PORT=8080
